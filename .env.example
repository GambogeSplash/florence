# ElevenLabs
ELEVENLABS_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Currency for payment links (lowercase ISO-4217). Defaults to "usd".
# For Nigerian small businesses you might want "ngn" — note Stripe must support it in your account.
STRIPE_CURRENCY=usd

# Public app URL (used by Stripe success URL). Leave blank in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: a pre-created demo agent_id used on /demo when no local setup exists.
# Create one via the /setup flow, then copy the printed agent_id here for hackathon video.
NEXT_PUBLIC_DEMO_AGENT_ID=
